#include <stdio.h>
#include <string.h>
#include <stdbool.h>

#define BUFFER_SIZE 10

typedef struct {
    char data_array[BUFFER_SIZE];
    int write_index;
    int read_index;
    int current_count;
} CircularBuffer;

void initBuffer(CircularBuffer *cb) {
    cb->write_index = 0;
    cb->read_index = 0;
    cb->current_count = 0;
}

bool isFull(CircularBuffer *cb) {
    return cb->current_count == BUFFER_SIZE;
}

bool isEmpty(CircularBuffer *cb) {
    return cb->current_count == 0;
}

void writeBuffer(CircularBuffer *cb, char character) {
    if (isFull(cb)) {
        printf("\n[Overflow] Buffer is full! Cannot add: '%c'", character);
        return;
    }
    cb->data_array[cb->write_index] = character;
    cb->write_index = (cb->write_index + 1) % BUFFER_SIZE;
    cb->current_count++;
}

char readBuffer(CircularBuffer *cb) {
    if (isEmpty(cb)) {
        printf("\n[Underflow] Buffer is empty!");
        return '\0';
    }
    char data = cb->data_array[cb->read_index];
    cb->read_index = (cb->read_index + 1) % BUFFER_SIZE;
    cb->current_count--;
    return data;
}

int main() {
    CircularBuffer myBuffer;
    initBuffer(&myBuffer);

    char userName[100];
    const char suffix[] = "CE-ESY";

    printf("Enter your name: ");
    if (fgets(userName, sizeof(userName), stdin)) {
        userName[strcspn(userName, "\n")] = 0;
    }

    strcat(userName, suffix);
    printf("String to process: %s\n", userName);
    printf("----------------------------------\n");

    for (int i = 0; i < strlen(userName); i++) {
        writeBuffer(&myBuffer, userName[i]);
    }

    printf("\nRetrieved from buffer: ");
    while (!isEmpty(&myBuffer)) {
        printf("%c", readBuffer(&myBuffer));
    }

    printf("\n----------------------------------\n");
    if (isEmpty(&myBuffer)) {
        printf("Status: Buffer is empty.\n");
    }

    return 0;
}
